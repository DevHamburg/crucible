# browserslist's electron-to-chromium / caniuse-lite update daily and routinely
# trip pnpm's minimum-release-age supply-chain gate. The lockfile pins them to
# aged versions (see pnpm.overrides), and this relaxes the age gate for this
# project's builds as a safety net. Raise the value (minutes) to re-enable, or
# prefer a surgical minimumReleaseAgeExclude allowlist.
minimum-release-age=0
