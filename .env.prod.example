# Crucible — server env template. On the server this lives at /opt/crucible/.env
# and is NOT overwritten by deploys (only IMAGE_TAG / GHCR_REPO get appended).
# Generate the two secrets once:
#   SECRET_KEY:      openssl rand -base64 48
#   ENCRYPTION_KEY:  python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

# --- image versioning (set/overwritten by the deploy workflow) ---
GHCR_REGISTRY=ghcr.io
GHCR_REPO=devhamburg/crucible
IMAGE_TAG=latest

# --- shared Caddy network (confirm with `docker network ls`) ---
EDGE_NETWORK=hypexio_web

# --- core secrets (REQUIRED) ---
SECRET_KEY=
ENCRYPTION_KEY=
POSTGRES_PASSWORD=change-me-strong

# --- app config ---
FRONTEND_ORIGIN=https://crucible.hypexio.com
ALLOW_ANONYMOUS=true
FIRST_ADMIN_EMAIL=admin@crucible.hypexio.com
FIRST_ADMIN_PASSWORD=change-me
GLOBAL_RUN_BUDGET_USD=25
MAX_CONCURRENCY=8

# --- judge / red-team defaults (mock keeps it free & offline) ---
JUDGE_MODEL=mock/judge-pro
REDTEAM_ATTACKER_MODEL=mock/redteam-adaptive

# --- optional provider keys (leave empty to run the simulated fleet only) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
