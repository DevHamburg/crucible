# ========================================================================
# Crucible — environment configuration
# Copy to .env and fill in. Everything has a safe local default so the
# stack runs WITHOUT any API keys (uses the built-in mock provider).
# ========================================================================

# ---- Core ----
CRUCIBLE_ENV=development                # development | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
# 32-byte urlsafe base64 key used to encrypt user API keys at rest.
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- Database ----
# Leave DATABASE_URL empty to use a local SQLite file (zero-setup dev mode).
# For Docker/production use the postgres URL (async driver):
# DATABASE_URL=postgresql+asyncpg://crucible:crucible@db:5432/crucible
DATABASE_URL=

# ---- Task queue / cache ----
# Leave REDIS_URL empty to run eval jobs in-process (no Redis needed for dev).
# REDIS_URL=redis://redis:6379/0
REDIS_URL=
USE_TASK_QUEUE=false                    # true -> use the arq worker (needs Redis)

# ---- Auth ----
ACCESS_TOKEN_EXPIRE_MINUTES=10080       # 7 days
ALLOW_ANONYMOUS=true                    # true -> usable without login (single-user mode)
FIRST_ADMIN_EMAIL=admin@crucible.local
FIRST_ADMIN_PASSWORD=admin

# ---- CORS / frontend ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Concurrency / limits ----
MAX_CONCURRENCY=8                       # parallel model calls per run
GLOBAL_RUN_BUDGET_USD=25                # hard cost ceiling per run (safety)
REQUEST_TIMEOUT_S=120

# ========================================================================
# Provider API keys (OPTIONAL — users can also enter keys in the UI).
# Server-level keys act as fallback/default when a user has none.
# ========================================================================
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
# Local models via Ollama (no key needed, just the base url):
OLLAMA_BASE_URL=http://localhost:11434

# ---- Default judge model (LLM-as-judge & red-team) ----
JUDGE_MODEL=openai/gpt-4o-mini          # openrouter-style id; overridable in UI
REDTEAM_ATTACKER_MODEL=openai/gpt-4o-mini

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
